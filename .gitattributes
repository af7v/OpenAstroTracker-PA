# Force LF line endings for all files that run on Linux
*.sh        text eol=lf
*.py        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf

# Debian packaging scripts (no extension) — must be LF or dpkg fails
debian/postinst  text eol=lf
debian/prerm     text eol=lf
debian/postrm    text eol=lf
debian/rules     text eol=lf
debian/control   text eol=lf
debian/changelog text eol=lf
debian/compat    text eol=lf
debian/copyright text eol=lf
